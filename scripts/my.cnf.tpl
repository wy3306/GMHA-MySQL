[mysql]
socket=__DATA_ROOT__/data/mysql.sock

[mysqld]
server_id = __SERVER_ID__
basedir = __BASE_DIR__
datadir = __DATA_ROOT__/data
character_sets_dir = __BASE_DIR__/share/charsets
plugin_dir = __BASE_DIR__/lib/plugin
port = __MYSQL_PORT__
socket = __DATA_ROOT__/data/mysql.sock
pid_file = __DATA_ROOT__/data/mysqld.pid
tmpdir = __DATA_ROOT__/tmp
character_set_server = utf8mb4
collation_server = utf8mb4_0900_ai_ci
autocommit = 1
transaction_isolation = READ-COMMITTED
lower_case_table_names = 1
interactive_timeout = 1800
wait_timeout = 1800
lock_wait_timeout = 1800
skip_name_resolve = 1
max_connections = 1000
max_connect_errors = 1000
max_allowed_packet = 64M
log_error = __DATA_ROOT__/data/mysqld.log
log_timestamps = SYSTEM
slow_query_log = 1
slow_query_log_file = __DATA_ROOT__/data/slow.log
long_query_time = 2
min_examined_row_limit = 100
log_slow_admin_statements = 1
log_slow_replica_statements = 1
log_throttle_queries_not_using_indexes = 10
log_bin = __DATA_ROOT__/binlog/mysql-bin
binlog_format = ROW
sync_binlog = 1
binlog_expire_logs_seconds = 604800
binlog_rows_query_log_events = 1
log_replica_updates = 1
gtid_mode = ON
enforce_gtid_consistency = ON
default_storage_engine = InnoDB
innodb_data_file_path = ibdata1:1024M:autoextend
innodb_temp_data_file_path = ibtmp1:512M:autoextend:max:30720M
innodb_undo_directory = __DATA_ROOT__/undo/__MYSQL_PORT__
innodb_log_group_home_dir = __DATA_ROOT__/redo/__MYSQL_PORT__
innodb_redo_log_capacity = __INNODB_REDO_LOG_CAPACITY__
innodb_flush_log_at_trx_commit = 1
innodb_lock_wait_timeout = 600
innodb_file_per_table = 1
innodb_flush_method = O_DIRECT
innodb_buffer_pool_size = __INNODB_BUFFER_POOL_SIZE__
innodb_buffer_pool_instances = 8
innodb_log_buffer_size = __INNODB_LOG_BUFFER_SIZE__
innodb_read_io_threads = 8
innodb_write_io_threads = 8
key_buffer_size = 32M
table_open_cache = 4096
thread_cache_size = __THREAD_CACHE_SIZE__
sort_buffer_size = 2M
join_buffer_size = 1M
read_buffer_size = 1M
read_rnd_buffer_size = 4M
tmp_table_size = __TMP_TABLE_SIZE__
max_heap_table_size = __TMP_TABLE_SIZE__
myisam_sort_buffer_size = 64M
